# Copy to .env and fill in. All keys are OPTIONAL — the tool runs fully without them
# on the free keyless providers (TheMuse, RemoteOK, Arbeitnow, Jobicy).

# Adzuna — best salary + CH/IE/NL/UK coverage. Free signup: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Claude Haiku enrichment (only needed with `--llm`). Cheapest model, ~$1/$5 per Mtok.
ANTHROPIC_API_KEY=
